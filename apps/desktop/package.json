{
  "name": "@antseed/desktop",
  "productName": "AntSeed Desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop app for AntSeed",
  "author": "AntSeed <hello@antseed.ai>",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "brand:electron-dev": "node ./scripts/brand-electron-dev.mjs",
    "ensure:native": "npm run ensure:runtime-native",
    "ensure:runtime-native": "node ./scripts/ensure-runtime-native-modules.mjs",
    "prebuild": "npm run brand:electron-dev && npm run ensure:native && rm -rf dist",
    "predev": "npm run brand:electron-dev && npm run ensure:native",
    "prestart": "npm run brand:electron-dev && npm run ensure:native",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5174 file:dist/main/main.js file:dist/main/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron .",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.54.2",
    "@mariozechner/pi-coding-agent": "^0.54.2",
    "@walletconnect/ethereum-provider": "^2.17.0",
    "ethers": "^6.13.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.6.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  }
}
